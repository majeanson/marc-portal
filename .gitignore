.wrangler-e2e
# Created by e2e/backend/setup.mjs while the e2e harness swaps in
# wrangler.e2e.toml. Restored by teardown.mjs. If you see it lying around,
# a prior run was interrupted — the next setup will self-heal.
wrangler.toml.bak
*.tsbuildinfo
prompt.log.jsonl
.claude

# Playwright — committed: e2e/__screenshots__ (baselines). Ignored: run output.
playwright-report
test-results
e2e/.cache

# Atelier gallery — regenerated from the baselines by build-atelier-gallery.mjs.
# The manifest src/data/atelier-gallery.json IS committed; these assets aren't.
public/atelier

# Local scratch — preview server log + throwaway screenshot scripts/output.
*.log
shot*
.walk-screenshots
