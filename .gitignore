node_modules
dist
.DS_Store
*.local
.env
.env.local
.dev.vars
.wrangler
.wrangler-e2e
# Created by e2e/backend/setup.mjs while the e2e harness swaps in
# wrangler.e2e.toml. Restored by teardown.mjs. If you see it lying around,
# a prior run was interrupted — the next setup will self-heal.
wrangler.toml.bak
*.tsbuildinfo
prompt.log.jsonl
.claude

# Playwright — committed: e2e/__screenshots__ (baselines). Ignored: run output.
playwright-report
test-results
e2e/.cache

# Atelier gallery — regenerated from the baselines by build-atelier-gallery.mjs.
# The manifest src/data/atelier-gallery.json IS committed; these assets aren't.
public/atelier

# Walkthrough — committed: the source (timeline.js, player.html, player.js) AND
# the capture output (manifest.json + frames/), so the /carte iframe player
# ships to prod. Refresh with `npm run walkthrough:capture` and re-commit —
# same discipline as the e2e visual baselines. Only the heavier rendered
# videos (a share/export artifact the embed doesn't use) stay out of git.
public/walkthrough/video/

# Local scratch — preview server log + throwaway screenshot scripts/output.
*.log
shot*
.walk-screenshots
scratch/
