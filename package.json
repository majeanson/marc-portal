{
  "name": "marc-portal",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "packageManager": "npm@10.9.0",
  "scripts": {
    "dev": "vite",
    "dev:cf": "wrangler pages dev --proxy 5180 --port 8788",
    "prebuild": "node scripts/build-sitemap.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lac-lint": "lac lint || echo 'skipping lac-lint (lac CLI not installed globally)'",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run lac-lint && npm run test:run",
    "db:migrate:local": "wrangler d1 migrations apply marc-portal-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply marc-portal-db --remote"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^2.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.4.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-checker": "^0.10.0",
    "vitest": "^2.1.9",
    "wrangler": "^4.0.0"
  }
}
